version: v1.25.0
ignore:
  SNYK-JS-BRACEEXPANSION-16755174:
    - '*':
        reason: >
          Vulnerability in npm's bundled brace-expansion. Not present in
          application dependencies. No fix available for npm 11.x on Node 24 LTS.
          Will resolve on next Node LTS upgrade.
        expires: '2026-08-20T00:00:00.000Z'
  SNYK-JS-UNDICI-17372658:
    - '*':
        reason: >
          Vulnerable undici version pinned by npm's bundled node-gyp
          dependency (node-gyp@12.x and 13.0.0 all declare undici@^6.25.0).
          Tested npm 11.13.0 / 11.14.0 / 11.16.0 / 11.17.0 — all resolve to
          a vulnerable undici version. Build-time tool only (node-gyp
          compiles native modules during install), not present in the
          running application's request path. No fix available until
          node-gyp bumps its undici dependency.
        expires: '2026-08-20T00:00:00.000Z'
  SNYK-JS-UNDICI-17372754:
    - '*':
        reason: >
          Same root cause as SNYK-JS-UNDICI-17372658 — vulnerable undici
          pinned via npm's bundled node-gyp dependency, build-time only,
          no fix currently available upstream.
        expires: '2026-08-20T00:00:00.000Z'
  SNYK-JS-UNDICI-17372758:
    - '*':
        reason: >
          Same root cause as SNYK-JS-UNDICI-17372658 — vulnerable undici
          pinned via npm's bundled node-gyp dependency, build-time only,
          no fix currently available upstream.
        expires: '2026-08-20T00:00:00.000Z'