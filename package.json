{
    "name": "cica-web",
    "version": "7.8.12",
    "engines": {
        "npm": ">=10.8.2",
        "node": ">=24.13.0"
    },
    "private": true,
    "scripts": {
        "start:dev": "npm run build:dev && nodemon -L --inspect=0.0.0.0:9229 -e .css,.js,.json,.njk --ignore public/dist/ --ignore src/js/scripts.babel.generated.js npm start",
        "start": "node ./bin/www",
        "sass": "sass --load-path=. --style=compressed --no-source-map src/sass/all.scss public/stylesheets/all.css",
        "test": "npm run test:node && npm run test:dom",
        "test:dom": "jest --config=jest.config.jsdom.js",
        "test:node": "jest --config=jest.config.js",
        "coverage": "jest --coverage --coverageReporters=html",
        "build:dev": "npm run babel && npm run webpack:dev",
        "build": "npm run babel && npm run webpack",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "buildRun:dev": "node ./bin/www",
        "webpack:dev": "webpack --config webpack.config.js",
        "webpack": "webpack --config webpack.config.prod.js",
        "babel": "babel src/js/scripts.js -o src/js/scripts.babel.generated.js"
    },
    "dependencies": {
        "@ministryofjustice/frontend": "^9.0.0",
        "cookie-parser": "~1.4.3",
        "csrf-csrf": "^4.0.3",
        "debug": "~4.4.3",
        "express": "^5.2.1",
        "express-openid-connect": "^2.18.1",
        "got": "^15.0.2",
        "helmet": "^8.1.0",
        "js-cookie": "^3.0.5",
        "lodash.merge": "^4.6.2",
        "moment-timezone": "^0.5.41",
        "morgan": "^1.10.1",
        "nanoid": "^5.1.9",
        "nunjucks": "^3.2.3",
        "q-transformer": "github:CriminalInjuriesCompensationAuthority/q-transformer#v5.4.0"
    },
    "devDependencies": {
        "@babel/cli": "^7.23.0",
        "@babel/core": "^7.23.2",
        "@babel/plugin-transform-runtime": "^7.23.2",
        "@babel/preset-env": "^7.23.2",
        "babel-loader": "^10.1.1",
        "core-js": "^3.29.0",
        "custom-event": "^1.0.1",
        "eslint": "^10.2.1",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.27.5",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "jest-fetch-mock": "^3.0.3",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.1.11",
        "prettier": "^3.8.3",
        "sass": "^1.62.1",
        "supertest": "^7.2.2",
        "time-convert": "0.0.2",
        "webpack": "^5.75.0",
        "webpack-cli": "^7.0.2"
    },
    "license": "MIT"
}
